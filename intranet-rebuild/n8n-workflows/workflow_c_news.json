    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const subject = item.json.subject || '';\n  let bodyText = item.json.text || item.json.html || '';\n\n  // Strip HTML tags if present\n  bodyText = bodyText.replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, '');\n  bodyText = bodyText.replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '');\n  bodyText = bodyText.replace(/<[^>]+>/g, '');\n  bodyText = bodyText.replace(/&nbsp;/g, ' ');\n  bodyText = bodyText.replace(/&amp;/g, '&');\n  bodyText = bodyText.replace(/&lt;/g, '<');\n  bodyText = bodyText.replace(/&gt;/g, '>');\n  bodyText = bodyText.replace(/\\s+/g, ' ').trim();\n\n  const fromHeader = item.json.from || '';\n  const emailMatch = fromHeader.match(/<([^>]+)>/) || fromHeader.match(/([\\w.-]+@[\\w.-]+)/);\n  const senderEmail = emailMatch ? emailMatch[1] : fromHeader;\n  const nameMatch = fromHeader.match(/^([^<]+)\\s*</);\n  const senderName = nameMatch ? nameMatch[1].trim().replace(/\"/g, '') : senderEmail;\n\n  results.push({\n    json: {\n      subject: subject,\n      body_text: bodyText,\n      sender_email: senderEmail,\n      sender_name: senderName\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000002",
      "name": "Extract Email Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [260, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 1024,\n  \"system\": \"Du bist interner Redakteur eines oesterreichischen Unternehmens. Erstelle einen sachlichen Intranet-Newsartikel (150-250 Woerter) aus den folgenden Stichpunkten. Ton: professionell, intern, keine Marketing-Sprache. Formatierung: Titel (max. 60 Zeichen) + 2-3 Absaetze. Antworte ausschliesslich mit validem JSON: {\\\"title\\\": \\\"...\\\", \\\"content\\\": \\\"...\\\"}\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Betreff: {{ $json.subject }}\\n\\nInhalt:\\n{{ $json.body_text }}\"\n    }\n  ]\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000003",
      "name": "Claude API Request",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "anthropic_api_key",
          "name": "Anthropic API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst emailData = $('Extract Email Content').first().json;\nconst results = [];\n\nfor (const item of items) {\n  let title = '';\n  let content = '';\n\n  try {\n    // Claude API response: content[0].text contains the JSON string\n    const responseText = item.json.content[0].text;\n\n    // Try to parse the JSON from Claude's response\n    // Handle cases where Claude may wrap JSON in markdown code blocks\n    let jsonStr = responseText;\n    const codeBlockMatch = responseText.match(/```(?:json)?\\s*([\\s\\S]*?)```/);\n    if (codeBlockMatch) {\n      jsonStr = codeBlockMatch[1].trim();\n    }\n\n    const parsed = JSON.parse(jsonStr);\n\n    if (parsed.title && parsed.content) {\n      title = parsed.title;\n      content = parsed.content;\n    } else {\n      throw new Error('Missing title or content in parsed JSON');\n    }\n  } catch (error) {\n    // Fallback: use email subject as title\n    title = emailData.subject || 'Neuer Artikel';\n    content = item.json.content && item.json.content[0]\n      ? item.json.content[0].text\n      : emailData.body_text || '';\n  }\n\n  const excerpt = content.substring(0, 160).replace(/<[^>]+>/g, '').trim();\n\n  results.push({\n    json: {\n      title: title,\n      content: content,\n      excerpt: excerpt,\n      sender_email: emailData.sender_email,\n      sender_name: emailData.sender_name,\n      original_subject: emailData.subject\n    }\n  });\n}\n\nreturn results;"
      },
