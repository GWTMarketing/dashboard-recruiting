      "id": "a1b2c3d4-0001-4000-8000-000000000001",
      "name": "IMAP Email Trigger",
      "type": "n8n-nodes-base.imapEmail",
      "typeVersion": 2,
      "position": [0, 300],
      "credentials": {
        "imap": {
          "id": "imap_news_inbox",
          "name": "News Mailbox IMAP"
        }
      },
      "webhookId": null
