        "subject": "=[Intranet] Neuer Artikel zur Freigabe: {{ $('Parse Claude Response').first().json.title }}",
        "emailType": "html",
        "html": "=<!DOCTYPE html>\n<html>\n<head><meta charset=\"utf-8\"></head>\n<body style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;\">\n  <h2 style=\"color: #333; border-bottom: 2px solid #0066cc; padding-bottom: 10px;\">Neuer Artikel zur Freigabe</h2>\n\n  <div style=\"background: #f5f5f5; border-left: 4px solid #0066cc; padding: 15px; margin: 20px 0;\">\n    <h3 style=\"margin-top: 0; color: #0066cc;\">{{ $('Parse Claude Response').first().json.title }}</h3>\n    <div style=\"color: #333; line-height: 1.6;\">{{ $('Parse Claude Response').first().json.content }}</div>\n  </div>\n\n  <p style=\"color: #666; font-size: 0.9em;\">Eingereicht von: {{ $('Parse Claude Response').first().json.sender_name }} ({{ $('Parse Claude Response').first().json.sender_email }})</p>\n  <p style=\"color: #666; font-size: 0.9em;\">WordPress Post-ID: {{ $json.id }}</p>\n\n  <div style=\"margin: 30px 0; text-align: center;\">\n    <a href=\"{{ $env.WEBHOOK_BASE_URL }}/webhook/article-approval?post_id={{ $json.id }}&action=publish&token={{ Buffer.from($json.id + '-publish-' + Date.now()).toString('base64url') }}\"\n       style=\"display: inline-block; background: #28a745; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; margin: 5px; font-weight: bold;\">\n      Freigeben\n    </a>\n    <a href=\"{{ $env.WEBHOOK_BASE_URL }}/webhook/article-approval?post_id={{ $json.id }}&action=reject&token={{ Buffer.from($json.id + '-reject-' + Date.now()).toString('base64url') }}\"\n       style=\"display: inline-block; background: #dc3545; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; margin: 5px; font-weight: bold;\">\n      Ablehnen\n    </a>\n  </div>\n\n  <hr style=\"border: none; border-top: 1px solid #ddd; margin: 20px 0;\">\n  <p style=\"color: #999; font-size: 0.8em;\">Diese E-Mail wurde automatisch von der News-Pipeline generiert.</p>\n</body>\n</html>",
        "options": {}
